{
  "app": {
    "first_run_initialized": true,
    "distro_folder_migrated": true
  },
  "ui": {
    "language": "es"
  },
  "ptyxis": {
    "opacity": 0.95
  },
  "wallpaper": {
    "folder": "./Wallpaper/Ubuntu",
    "interval_minutes": 30,
    "extensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".bmp",
      ".svg",
      ".webp"
    ],
    "set_dark_variant": true,
    "search_subfolders": false
  }
}
